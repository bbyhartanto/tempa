---

<section
	class="min-h-screen flex flex-col justify-center border-b-1 border-gray-200 px-8"
>
	<div class="grid grid-cols-1 md:grid-cols-10 gap-2 py-10 pt-20">
		<div class="col-span-full md:px-0 md:col-span-5 md:col-start-2">
			<h3>Our services</h3>
			<h2 class="md:text-h2 font-medium text-6xl">
				A suite of tech service designed to help brands show and grow.
			</h2>
		</div>
	</div>
	<div class="grid grid-cols-1 md:grid-cols-10 gap-8 pb-20">
		<!-- Card 1: Storefronts & Landing Pages -->
		<div
			class="grid col-span-1 md:col-start-2 md:col-span-2 gap-4 reveal md:px-0"
			style="animation-delay: 0.5s"
		>
			<div>
				<span class="text-2xl">🛍️</span>
				<h4 class="pt-4 text-2xl">Storefronts & e-commerce</h4>
			</div>
			<p>
				Enterprise-grade e-commerce website accessible to brands of all
				sizes.
			</p>
		</div>
		<!-- Card 2: Brand & Company Websites -->
		<div
			class="grid col-span-1 md:col-span-2 gap-4 reveal md:px-0"
			style="animation-delay: 0.62s"
		>
			<div>
				<span class="text-2xl">🏢</span>
				<h4 class="pt-4 text-2xl">Brand & Company Websites</h4>
			</div>
			<p>
				Digital presence to impress your partners, clients, and
				stakeholders.
			</p>
		</div>
		<!-- Card 3: Mobile Apps -->
		<div
			class="grid col-span-1 md:col-span-2 gap-4 reveal md:px-0"
			style="animation-delay: 0.74s"
		>
			<div>
				<span class="text-2xl">📱</span>
				<h4 class="pt-4 text-2xl">Mobile Apps</h4>
			</div>
			<p>
				Design and develop mobile experiences that extend your reach
				beyond the browser.
			</p>
		</div>
		<!-- Card 4: Social Media Management -->
		<div
			class="grid col-span-1 md:col-span-2 gap-4 reveal md:px-0"
			style="animation-delay: 0.86s"
		>
			<div>
				<span class="text-2xl">📣</span>
				<h4 class="pt-4 text-2xl">Social Media Management</h4>
			</div>
			<p>
				Managing your content calendar, creative direction, and posting.
				Strategy-led, brand-aligned, growth-focused.
			</p>
		</div>
	</div>
</section>
