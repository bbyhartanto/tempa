<script>
	import { gsap } from "gsap";

	const track = document.querySelector(".marquee-track");
	if (track) {
		// Create the infinite marquee tween
		let marqueeTween = gsap.to(track, {
			xPercent: -50,
			ease: "none",
			duration: 20,
			repeat: -1,
		});

		// Listen for wheel events to speed up the marquee temporarily
		let scrollTimeout;
		window.addEventListener("wheel", (e) => {
			// Determine direction to speed up (forward or backward)
			// A simple speed boost:
			gsap.to(marqueeTween, {
				timeScale: 4,
				duration: 0.3,
				overwrite: true,
			});

			clearTimeout(scrollTimeout);
			scrollTimeout = setTimeout(() => {
				// Return to normal speed after scrolling stops
				gsap.to(marqueeTween, {
					timeScale: 1,
					duration: 1,
					ease: "power2.out",
					overwrite: true,
				});
			}, 100);
		});
	}
</script>
