---
import Layout from "../layouts/home.astro";
import "../styles/global.css";
import "../styles/home.css";
import SectionServices from "../components/SectionServices.astro";
import SectionTechStack from "../components/SectionTechStack.astro";

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
	<section class="relative min-h-screen flex flex-col">
		<!-- Background Grid -->
		<div
			class="absolute inset-0 grid grid-cols-4 md:grid-cols-8 gap-[1px] bg-gray-200 z-0 pointer-events-none"
		>
			<div class="bg-[#ffffff]"></div>
			<div class="bg-[#ffffff]"></div>
			<div class="bg-[#ffffff]"></div>
			<div class="bg-[#ffffff]"></div>
			<!-- md hidden -->
			<div class="hidden md:block bg-[#ffffff]"></div>
			<div class="hidden md:block bg-[#ffffff]"></div>
			<div class="hidden md:block bg-[#ffffff]"></div>
			<div class="hidden md:block bg-[#ffffff]"></div>
		</div>

		<!-- Foreground Content -->
		<div
			class="relative z-10 grid grid-cols-4 md:grid-cols-8 items-end mt-20"
		>
			<div
				class="col-span-1 md:col-span-1 md:col-start-4 pointer-events-auto aspect-square overflow-hidden"
			>
				<img
					src="/home-img/hat.webp"
					alt="image hat online"
					class="w-full h-full object-cover"
				/>
			</div>
			<div></div>
			<div
				class="col-span-1 md:col-span-1 md:col-start-6 pointer-events-auto aspect-square overflow-hidden"
			>
				<img
					src="/home-img/shirt.webp"
					alt="image hat online"
					class="w-full h-full object-cover"
				/>
			</div>

			<div
				class="col-span-1 md:col-span-1 pointer-events-auto aspect-square overflow-hidden"
			>
				<img
					src="/home-img/wem.webp"
					alt="image hat online"
					class="w-full h-full object-cover"
				/>
			</div>
		</div>
		<!-- row 2 -->
		<div class="relative z-10 grid grid-cols-4 md:grid-cols-8 items-start">
			<div
				class="col-span-4 md:col-span-4 md:col-start-2 p-4 pointer-events-auto @container"
			>
				<!-- The text size uses Container Query units (cqw) to scale relative to the parent div's width -->
				<!-- 25cqw means 25% of the container's width. You can adjust this number to fit perfectly -->
				<p>Introducing</p>
				<h3
					class="reveal panchang-medium uppercase text-[18cqw] md:text-[22cqw] leading-none whitespace-nowrap relative z-20"
				>
					Tempa
				</h3>
			</div>
			<div
				class="hidden md:block col-span-1 md:col-span-2 md:col-start-2 p-4 pointer-events-auto text-xl"
			>
				<p>
					Web studio specializing in UI/UX design and web development.
					Custom website and e-commerce optimized for conversion and
					performance.
				</p>
			</div>
			<div
				class="col-span-1 col-start-2 md:col-span-1 md:col-start-4 pointer-events-auto aspect-square overflow-hidden"
			>
				<img
					src="/home-img/socks.webp"
					alt="image hat online"
					class="w-full h-full object-cover"
				/>
			</div>
			<div
				class="col-span-4 col-start-3 md:col-span-3 md:col-start-5 p-4 pointer-events-auto @container"
			>
				<!-- The text size uses Container Query units (cqw) to scale relative to the parent div's width -->
				<!-- 25cqw means 25% of the container's width. You can adjust this number to fit perfectly -->
				<h3
					class="reveal panchang-regular uppercase text-[18cqw] leading-none whitespace-nowrap"
				>
					Studio
				</h3>
			</div>
		</div>
		<!-- row 3 -->
		<div class="relative z-10 grid grid-cols-4 md:grid-cols-8 items-start">
			<div
				class="col-span-1 col-start-2 md:col-span-1 md:col-start-5 pointer-events-auto aspect-square overflow-hidden"
			>
				<img
					src="/home-img/hat.webp"
					alt="image hat online"
					class="w-full h-full object-cover"
				/>
			</div>
			<div class="col-span-2 md:hidden p-4 pointer-events-auto">
				<p>
					Web studio specializing in UI/UX design and web development.
					Custom website and e-commerce optimized for conversion and
					performance.
				</p>
			</div>
		</div>
	</section>
	<SectionServices />
	<SectionTechStack />
	<!-- call to action -->
	<section class="min-h-[800px] flex flex-col justify-center">
		<div class="grid grid-cols-1 md:grid-cols-10 gap-2 py-10">
			<div
				class="col-start-1 col-span-1 md:col-start-2 md:col-span-8 pt-8 px-8"
			>
				<h2 class="text-h2">
					First impression matters. Make it count with a landing page
					that converts.
				</h2>
				<a
					href="#"
					class="inline-block w-fit mt-6 px-8 py-4 bg-black text-white rounded-full font-medium transition-all duration-300 hover:bg-gray-800 hover:-translate-y-1 hover:shadow-lg"
				>
					Book your web assesment call now
				</a>
			</div>
		</div>
	</section>
	<!-- services section -->

	<script>
		import { gsap } from "gsap";
		import { ScrollTrigger } from "gsap/ScrollTrigger";

		gsap.registerPlugin(ScrollTrigger);

		// 1. Hero Section Complex Timeline
		const heroTl = gsap.timeline({ defaults: { ease: "power3.out" } });

		// Hide elements initially via GSAP to prevent FOUC for elements not hidden by CSS
		gsap.set("section:first-of-type img", { opacity: 0, y: 40 });
		gsap.set("section:first-of-type p", { opacity: 0, y: 20 });

		heroTl
			.to("section:first-of-type img", {
				duration: 1.2,
				y: 0,
				opacity: 1,
				stagger: 0.15,
				delay: 0.1,
			})
			.to(
				"section:first-of-type p",
				{
					duration: 0.8,
					y: 0,
					opacity: 1,
					stagger: 0.1,
				},
				"-=0.6"
			);

		// 2. Global ScrollTrigger for .reveal and .tablinks
		const revealElements = document.querySelectorAll(
			".reveal:not(.slide-left), .tablinks"
		);
		revealElements.forEach((el) => {
			gsap.to(el, {
				scrollTrigger: {
					trigger: el,
					start: "top 85%",
					toggleActions: "play none none reverse", // Play on enter, reverse on leave
				},
				opacity: 1,
				y: 0,
				duration: 0.6,
				ease: "power2.out",
			});
		});

		// 3. ScrollTrigger for .reveal.slide-left
		const slideLeftElements =
			document.querySelectorAll(".reveal.slide-left");
		slideLeftElements.forEach((el) => {
			gsap.to(el, {
				scrollTrigger: {
					trigger: el,
					start: "top 85%",
					toggleActions: "play none none reverse",
				},
				opacity: 1,
				x: 0,
				duration: 0.6,
				ease: "power2.out",
			});
		});
	</script>
</Layout>
