---
import Layout from "../layouts/home.astro";
import "../styles/global.css";
import "../styles/home.css";

// Welcome to Astro! Wondering what to do next? Check out the Astro documentation at https://docs.astro.build
// Don't want to use any of this? Delete everything in this file, the `assets`, `components`, and `layouts` directories, and start fresh.
---

<Layout>
	<section class="hero bg-[#0047CC] text-gray-50">
		<div class="hero-content">
			<div class="grid grid-cols-1 md:grid-cols-6 gap-2">
				<div class="col-span-1 md:col-start-2">
					<img
						class="w-full h-[300px] object-cover"
						src="/home-img/hat.webp"
						alt="images"
					/>
				</div>

				<div
					class="flex flex-col col-span-1 md:col-span-2 md:col-start-3 w-full items-center justify-center"
				>
					<div class="col-span-1">
						<div class="flex flex-col justify-center items-center">
							<img src="/brand/tempa-logo-white.svg" alt="" />
							<h2 class="font-bold text-2xl">Tempa studio</h2>
						</div>
					</div>
				</div>
				<div class="col-span-1">
					<img
						class="w-full h-[200px] object-cover"
						src="/home-img/shirt.webp"
						alt="images"
					/>
				</div>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-5 gap-2">
				<div class="col-span-1 h-full items-end">
					<img
						class="w-full h-[280px] object-cover"
						src="/home-img/wem.webp"
						alt="images"
					/>
				</div>
				<div
					class="col-span-1 md:col-span-3 px-10 w-full flex text-center justify-center items-center"
				>
					<h2 class="text-h2">
						We are digital enabler for emerging to mid-market brands
					</h2>
				</div>
				<div class="col-span-1">
					<img
						class="w-full h-[300px] object-cover"
						src="/home-img/socks.webp"
						alt="images"
					/>
				</div>
			</div>
			<div
				class="w-full grid grid-cols-1 md:grid-cols-8 gap-2 justify-center items-center min-h-[250px]"
			>
				<div
					class="col-span-1 md:col-span-4 md:col-start-3 text-center justify-center px-4 md:px-0"
				>
					<h2>
						Tempa is a digital consultancy collective combining
						design consulting, creativity, technology, engineering
						and data to help brand owners get better business result
					</h2>
				</div>
				<div
					class="md:col-start-3 md:col-span-4 w-full flex flex-wrap items-center justify-center py-8 px-4 md:px-0 gap-4 md:gap-0"
				>
					<img
						class="w-1/5 md:w-1/5 lg:w-1/7 h-full object-cover"
						src="/stacks/astro.svg"
						alt="images"
					/>
					<img
						class="w-1/5 md:w-1/5 lg:w-1/7 h-full object-cover"
						src="/stacks/vue.svg"
						alt="images"
					/>
					<img
						class="w-1/5 md:w-1/5 lg:w-1/7 h-full object-cover"
						src="/stacks/shopify.svg"
						alt="images"
					/>
					<img
						class="w-1/5 md:w-1/5 lg:w-1/7 h-full object-cover"
						src="/stacks/wordpress.svg"
						alt="images"
					/>
					<img
						class="w-1/5 md:w-1/5 lg:w-1/7 h-full object-cover"
						src="/stacks/woo.svg"
						alt="images"
					/>
				</div>
			</div>
		</div>
	</section>
	<section class="border-b-1 border-gray-200 pb-10">
		<div class="grid grid-cols-1 md:grid-cols-10 gap-2 py-10">
			<div
				class="col-span-full px-4 md:px-0 md:col-span-8 md:col-start-2"
			>
				<h2 class="text-2xl sm:text-2xl md:text-4xl">
					Build your e-commerce website
				</h2>
				<form class="grid grid-cols-1 md:grid-cols-4 gap-2 pt-4">
					<input
						type="text"
						placeholder="Name your brand"
						class="col-span-1 md:col-span-2 w-full border border-gray-300 px-3 py-2 outline-none focus:border-gray-500 focus:ring-1 focus:ring-gray-400 transition-colors"
					/>
					<select
						name="ecom-type"
						id=""
						class="col-span-1 w-full border border-gray-300 px-3 py-2 outline-none focus:border-gray-500 focus:ring-1 focus:ring-gray-400 transition-colors"
					>
						<option value="">E-commerce Type</option>
						<option value="wordpress">Fashion</option>
						<option value="shopify">FnB</option>
					</select>
					<button
						type="submit"
						class="col-span-1 w-full bg-[#0047CC] text-gray-50 px-8 py-2"
					>
						Book consultancy
					</button>
				</form>
			</div>
		</div>
	</section>

	<!-- e commerce section -->
	<section class="min-h-[800px] flex flex-col justify-center">
		<div class="w-[400px] h-full absolute">
			<img
				class="w-full h-full object-cover"
				src="/home-img/satisfy.png"
				alt="images"
			/>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-10 gap-2 py-10">
			<div
				class="col-start-1 col-span-1 md:col-start-4 md:col-span-6 pt-8"
			>
				<h3>Build - e-commerce with Tempa</h3>
				<h2 class="text-h2">
					We make enterprise-grade <br /> e-commerce website accessible
					to brands of all sizes.
				</h2>
			</div>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-10 gap-8">
			<div
				class="grid col-span-1 md:col-start-4 md:col-span-2 gap-4 reveal"
				style="animation-delay: 0.5s"
			>
				<h4 class="pt-10 text-2xl">E-commerce Migration</h4>
				<p>
					Migrate from existing e-commerce platform to another
					platform.
				</p>
				<ul class="list-none list-inside">
					<li class="li-migrate">Migrate from Tokopedia</li>
					<li class="li-migrate">Migrate from Shopee</li>
					<li class="li-migrate">Migrate from tiktokshop</li>
					<li class="li-migrate">Migrate from Shopify</li>
				</ul>
			</div>
			<div
				class="grid col-span-1 md:col-span-2 reveal px-4 md:px-0"
				style="animation-delay: 0.62s"
			>
				<h4 class="pt-10 text-2xl">
					Design built around your brand — not a template
				</h4>
				<p>
					From Ui & UX to production, we tailor made your digital
					presence without shortcuts.
				</p>
			</div>
			<div
				class="grid col-span-1 md:col-span-2 reveal px-4 md:px-0"
				style="animation-delay: 0.74s"
			>
				<h4 class="pt-10 text-2xl">
					Craft your product content strategy
				</h4>
				<p>
					Product presentation is king. We shape how your products are
					described, positioned, and presented, so customers feel
					compelled to buy.
				</p>
			</div>
		</div>
	</section>
	<!-- landing page section -->
	<section class="min-h-[800px] flex flex-col justify-center">
		<div class="grid grid-cols-1 md:grid-cols-10 gap-2 py-10">
			<div
				class="col-start-1 col-span-1 md:col-start-4 md:col-span-6 pt-8"
			>
				<h3>Others we do</h3>
				<h2 class="text-h2">
					First impression matters. Make it count with a landing page
					that converts.
				</h2>
			</div>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-10 gap-8">
			<div
				class="grid col-span-1 md:col-start-4 md:col-span-2 gap-4 reveal"
				style="animation-delay: 0.5s"
			>
				<h4 class="pt-10 text-2xl">Company profile built</h4>
				<p>
					No bloated platforms, no unnecessary complexity. Just the
					right foundation techstack to grow on.
				</p>
			</div>
			<div
				class="grid col-span-1 md:col-span-2 reveal px-4 md:px-0"
				style="animation-delay: 0.62s"
			>
				<h4 class="pt-10 text-2xl">
					Design built around your brand — not a template
				</h4>
				<p>
					From Ui & UX to production, we tailor made your digital
					presence without shortcuts.
				</p>
			</div>
			<div
				class="grid col-span-1 md:col-span-2 reveal px-4 md:px-0"
				style="animation-delay: 0.74s"
			>
				<h4 class="pt-10 text-2xl">
					Craft your product content strategy
				</h4>
				<p>
					Product presentation is king. We shape how your products are
					described, positioned, and presented, so customers feel
					compelled to buy.
				</p>
			</div>
		</div>
	</section>
	<!-- services section -->
	<section class="min-h-screen flex flex-col justify-center">
		<div class="grid grid-cols-1 md:grid-cols-10 gap-2 mt-20">
			<div class="tab col-span-1 md:col-span-2 md:col-start-2">
				<h4>SERVICES</h4>
			</div>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-10 gap-2 mt-8 h-[100px]">
			<div class="tab col-span-1 md:col-span-3 md:col-start-2">
				<button
					class="tablinks text-h2 text-left"
					style="animation-delay: 0.5s"
					onmouseover="openContent(event, 'London')"
					onmouseout="closeCity(event, 'London')">Creative</button
				>
			</div>
			<div
				id="London"
				class="tabcontent col-span-1 md:col-span-3 gap-4"
				style="display: none;"
			>
				<div>
					<h3 class="text-2xl">Branding</h3>
					<div class="flex flex-wrap gap-2 pt-4">
						<span class="tablet">Graphic design assets</span>
						<span class="tablet">Creative & Art direction</span>
						<span class="tablet">Branding & Identity</span>
						<span class="tablet">Animation & Interaction</span>
						<span class="tablet">Packaging design</span>
						<span class="tablet">3d production</span>
						<span class="tablet">Video production</span>
					</div>
				</div>
			</div>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-10 gap-2 h-[100px] mt-8">
			<div class="tab col-span-1 md:col-span-3 md:col-start-2">
				<button
					class="tablinks text-h2 text-left"
					style="animation-delay: 0.62s"
					onmouseover="openContent(event, 'Design')"
					onmouseout="closeCity(event, 'Design')">UI/UX</button
				>
			</div>
			<div
				id="Design"
				class="tabcontent col-span-1 md:col-span-3 gap-4"
				style="display: none;"
			>
				<div>
					<h3 class="text-2xl">UI Design</h3>
					<div class="flex flex-wrap gap-2 pt-4">
						<span class="tablet"
							>UI design consultation & Audit</span
						>
						<span class="tablet">User Interface (UI) Design</span>
						<span class="tablet">Creative & Art direction</span>
						<span class="tablet">Branding & Identity</span>
						<span class="tablet">Design System</span>
						<span class="tablet">Animation & Interaction</span>
						<span class="tablet">Packaging design</span>
						<span class="tablet">3d production</span>
						<span class="tablet">Email design</span>
					</div>
				</div>
				<div class="mt-8">
					<h3 class="text-2xl">UX</h3>
					<div class="flex flex-wrap gap-2 pt-4">
						<span class="tablet">UX Audit & Strategy</span>
						<span class="tablet">User Research</span>
						<span class="tablet">Information Architecture</span>
						<span class="tablet">Interaction Design</span>
						<span class="tablet">Prototyping</span>
						<span class="tablet">User Testing</span>
						<span class="tablet">Wireframing</span>
					</div>
				</div>
			</div>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-10 mt-8 gap-2 h-[200px]">
			<div class="tab col-span-1 md:col-span-3 md:col-start-2">
				<button
					class="tablinks text-h2 text-left"
					style="animation-delay: 0.74s"
					onmouseover="openContent(event, 'Paris')"
					onmouseout="closeCity(event, 'Paris')">Technology</button
				>
			</div>
			<div
				id="Paris"
				class="tabcontent col-span-1 md:col-span-3 gap-4"
				style="display: none;"
			>
				<div>
					<h3 class="text-2xl">Frontend Development</h3>
					<div class="flex flex-wrap gap-2 pt-4">
						<span class="tablet">E-commerce theme development</span>
						<span class="tablet">Headless website development</span>
						<span class="tablet">Shopify theme development</span>
						<span class="tablet">Landing page development</span>
						<span class="tablet">WordPress development</span>
					</div>
				</div>
				<div class="mt-8">
					<h3 class="text-2xl">Backend Development</h3>
					<div class="flex flex-wrap gap-2 pt-4">
						<span class="tablet">ERP customization</span>
						<span class="tablet">Custom mobile app development</span
						>
						<span class="tablet">Custom web app development</span>
						<span class="tablet">API Integration</span>
						<span class="tablet">Data Migration</span>
						<span class="tablet">Managed IT services</span>
					</div>
				</div>
			</div>
		</div>
	</section>
	<!-- Footer -->
	<section
		class="grid grid-cols-1 md:grid-cols-10 gap-2 mt-20 min-h-[30vh] bg-[#0a0d25] text-white"
	>
		<div class="col-span-1 flex items-center md:col-span-2 md:col-start-2">
			<h2 class="text-4xl md:text-4xl">Ready to start something new?</h2>
		</div>
		<div
			class="col-span-1 md:col-span-2 md:col-start-9 flex items-center"
			style="animation-delay: 1s"
		>
			<div class="px-4 py-2 bg-[#ffffff]">
				<h3 class="text-2xl text-black">Build with us</h3>
			</div>
		</div>
	</section>

	<script is:inline>
		function openContent(evt, cityName) {
			var i, tabcontent, tablinks;
			// Hide all tab content
			tabcontent = document.getElementsByClassName("tabcontent");
			for (i = 0; i < tabcontent.length; i++) {
				tabcontent[i].style.display = "none";
			}
			// Remove "active" class and add/remove "muted" on all buttons
			tablinks = document.getElementsByClassName("tablinks");
			for (i = 0; i < tablinks.length; i++) {
				tablinks[i].className = tablinks[i].className.replace(
					" active",
					""
				);
				if (tablinks[i] !== evt.currentTarget) {
					if (!tablinks[i].classList.contains("muted")) {
						tablinks[i].classList.add("muted");
					}
				} else {
					tablinks[i].classList.remove("muted");
				}
			}
			// Show the specific tab content and mark button as active
			var el = document.getElementById(cityName);
			el.style.animation = "none";
			el.style.display = "block";
			el.offsetHeight; // force reflow to restart animation
			el.style.animation = "";
			evt.currentTarget.className += " active";
		}

		function closeCity(evt, cityName) {
			document.getElementById(cityName).style.display = "none";
			evt.currentTarget.className = evt.currentTarget.className.replace(
				" active",
				""
			);
			// Remove muted from all buttons when hover ends
			var tablinks = document.getElementsByClassName("tablinks");
			for (var i = 0; i < tablinks.length; i++) {
				tablinks[i].classList.remove("muted");
			}
		}

		// Trigger .reveal animation every time element enters viewport
		const revealObserver = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						entry.target.classList.add("in-view");
					} else {
						entry.target.classList.remove("in-view"); // reset so animation replays on re-entry
					}
				});
			},
			{ threshold: 0.15 }
		);

		document.querySelectorAll(".reveal, .tablinks").forEach((el) => {
			revealObserver.observe(el);
		});
	</script>
</Layout>
